<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Anime Events</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
<header>
    <nav class="navbar navbar-dark bg-dark navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Anime Events
            </a>

            <div>
                <a class="btn btn-outline-light me-2" asp-controller="Events" asp-action="Index">
                    Eventos
                </a>
                <a class="btn btn-warning" asp-controller="Events" asp-action="Create">
                    Crear Evento
                </a>
            </div>
        </div>
    </nav>
</header>

<main class="container mt-4">
    @RenderBody()
</main>

<footer class="bg-dark text-white text-center p-3 mt-4">
    © 2026 - Anime Events
</footer>
</body>
</html>